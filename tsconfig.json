{
  "compilerOptions": {
    "outDir": "dist",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "target": "esnext",
    "module": "esnext",
    "allowJs": true,
    "checkJs": true,
    "skipLibCheck": true,
    "noEmit": true,
    "plugins": [
      {
        "name": "typescript-plugin-css-modules",
        "options": {
          "customMatcher": ".module.css",
          "namedExports": false
        }
      }
    ]
  },
  "exclude": ["node_modules", "dist"]
}
